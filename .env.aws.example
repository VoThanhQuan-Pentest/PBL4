# Lab-only Web EC2 environment. Copy to /opt/flare/.env and replace every
# password/JWT placeholder locally; this template must never be used as a secret.
SPRING_PROFILES_ACTIVE=dev
MYSQL_USER=flare_app
MYSQL_PASSWORD=replace-with-random-16-plus-character-password
MYSQL_ROOT_PASSWORD=replace-with-different-random-16-plus-character-password
SPRING_DATASOURCE_USERNAME=flare_app
SPRING_DATASOURCE_PASSWORD=replace-with-random-16-plus-character-password
REDIS_PASSWORD=replace-with-random-16-plus-character-password
APP_JWT_SECRET=replace-with-at-least-32-random-characters
APP_MAIL_USERNAME=
APP_MAIL_FROM=
APP_MAIL_PASSWORD=
APP_AUTH_COOKIE_SECURE=false
HTTP_HOST_PORT=80
FLARE_INTERNAL_SUBNET=172.30.0.0/24
NGINX_TRUSTED_PROXY_CIDR=192.0.2.1/32
NGINX_PUBLIC_SERVER_NAME=REPLACE_WITH_WEB_ELASTIC_IP
APP_CORS_ALLOWED_ORIGINS=http://REPLACE_WITH_WEB_ELASTIC_IP
FILEBEAT_LOGSTASH_HOST=10.20.10.20:5044
FILEBEAT_CERTS_DIR=/opt/flare/.secrets/observability/web
