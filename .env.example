# Local development template only. The placeholder values below are intentionally
# rejected by the production startup checks until they are replaced.
SPRING_PROFILES_ACTIVE=
MYSQL_USER=flare_app
MYSQL_PASSWORD=change-this-database-password
MYSQL_ROOT_PASSWORD=change-this-root-password
SPRING_DATASOURCE_USERNAME=flare_app
SPRING_DATASOURCE_PASSWORD=change-this-database-password
REDIS_PASSWORD=change-this-redis-password
APP_JWT_SECRET=replace-with-at-least-32-random-characters
APP_MAIL_USERNAME=
APP_MAIL_FROM=
APP_MAIL_PASSWORD=
# This is intentionally false for local HTTP. Production must set it to true.
APP_AUTH_COOKIE_SECURE=false
HTTP_HOST_PORT=80
FLARE_INTERNAL_SUBNET=172.30.0.0/24
# Development origins. Production accepts explicit HTTPS origins only.
APP_CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,https://flarefitness.site,https://www.flarefitness.site
# Keep this TEST-NET value for direct Nginx. Set it to the private CIDR of the
# immediate TLS terminator only when deploying behind a trusted proxy/load balancer.
NGINX_TRUSTED_PROXY_CIDR=192.0.2.1/32
# AWS lab: set this to the Web Elastic IP so direct Host validation accepts it.
NGINX_PUBLIC_SERVER_NAME=localhost
# The Filebeat service is opt-in via `--profile observability`; mTLS files live
# outside Git under FILEBEAT_CERTS_DIR and this address is Monitor's private IP.
FILEBEAT_LOGSTASH_HOST=10.20.10.20:5044
FILEBEAT_CERTS_DIR=./.secrets/observability/web
